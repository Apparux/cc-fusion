{
  "name": "cc-fusion",
  "version": "1.1.2",
  "description": "Claude Code statusline: CCometixLine beauty + Claude HUD functionality",
  "main": "dist/index.js",
  "bin": {
    "cc-fusion": "dist/index.js"
  },
  "files": [
    "dist/",
    "src/",
