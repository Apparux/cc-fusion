  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "ansi-escapes": "^7.3.0",
    "chalk": "^5.6.2",
    "cli-cursor": "^5.0.0",
    "strip-ansi": "^7.2.0"
  }
